---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="min-h-screen px-6 sm:px-10 lg:px-[10%] py-20 sm:py-24 lg:py-32 bg-[#f8f8f6] text-black">
    <div class="max-w-6xl mx-auto">

      <a
        href="/portfolio/"
        class="inline-flex items-center gap-3 mb-14 sm:mb-16 lg:mb-20 text-xs sm:text-sm uppercase tracking-[0.2em]
        text-gray-500 hover:text-black transition duration-300 group"
      >
        <span
          class="w-8 sm:w-10 h-[1px] bg-gray-400
          group-hover:w-14 group-hover:bg-black
          transition-all duration-300"
        ></span>

        Volver
      </a>

      <div class="mb-16 sm:mb-20 lg:mb-24">
        <p class="text-xs sm:text-sm tracking-[0.3em] uppercase text-gray-500 mb-4">
          Contacto
        </p>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold leading-tight max-w-5xl">
          Trabajemos juntos.
        </h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-14 sm:gap-16 lg:gap-20 items-start md:items-end">

        <div>
          <p class="text-lg sm:text-xl leading-relaxed text-gray-700 max-w-xl">
            Disponible para proyectos, colaboración y oportunidades.
          </p>
        </div>

        <div class="md:text-right">
          <p class="text-xs sm:text-sm uppercase tracking-[0.2em] text-gray-500 mb-4">
            Email
          </p>

          <a
            href="mailto:codebrielz@gmail.com"
            class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight
            break-words
            text-transparent bg-clip-text
            bg-[linear-gradient(90deg,#111827,#6b7280,#111827)]
            bg-[length:300%_100%] animate-gradient
            hover:opacity-60 transition"
          >
            mrcausalidad@gmail.com
          </a>
        </div>

      </div>

      <div class="mt-20 sm:mt-24 lg:mt-32 h-[1px] w-full bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>

    </div>
  </section>
</Layout>