---
const base = import.meta.env.BASE_URL;

const route = (path: string) => {
  return `${base}/${path}`.replace(/\/+/g, "/");
};
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden px-6 md:px-8">

  <div class="hidden lg:flex absolute left-[8%] flex-col gap-20 z-20">
    <a href={route("projects")} class="group relative">
      <div
        class="absolute top-1/2 right-[-180px] w-[160px] h-[1px]
        bg-gradient-to-r from-gray-600/100 to-transparent
        group-hover:w-[200px] transition-all duration-500"
      ></div>

      <span class="px-6 py-3 text-3xl transition-all duration-300 inline-block">
        Proyectos
      </span>
    </a>

    <a href={route("about")} class="group relative">
      <div
        class="absolute top-1/2 right-[-180px] w-[160px] h-[1px]
        bg-gradient-to-r from-gray-600/100 to-transparent
        group-hover:w-[200px] transition-all duration-500"
      ></div>

      <span class="px-6 py-3 text-3xl transition-all duration-300 inline-block">
        Sobre mí
      </span>
    </a>
  </div>

  <div class="relative z-30 flex flex-col items-center justify-center text-center w-full max-w-4xl">

    <nav class="lg:hidden mb-10 sm:mb-12 flex flex-col gap-5 sm:gap-6">
      <a
        href={route("projects")}
        class="group text-xl sm:text-2xl font-semibold"
      >
        <span class="block h-[1px] w-12 mx-auto mb-3 bg-gray-400 group-hover:w-20 transition-all duration-300"></span>
        Proyectos
      </a>

      <a
        href={route("about")}
        class="group text-xl sm:text-2xl font-semibold"
      >
        <span class="block h-[1px] w-12 mx-auto mb-3 bg-gray-400 group-hover:w-20 transition-all duration-300"></span>
        Sobre mí
      </a>
    </nav>

    <h1 class="text-4xl sm:text-5xl md:text-7xl font-semibold tracking-tight leading-tight">
      Hola, soy
      <span
        class="block sm:inline text-transparent bg-clip-text
        bg-[linear-gradient(90deg,#6b7280,#9ca3af,#4b5563,#d1d5db)]
        bg-[length:300%_100%] animate-gradient"
      >
        Gabriel
      </span>
    </h1>

    <span
      class="mt-4 sm:mt-6 inline-block px-5 py-2 text-xs sm:text-sm font-semibold
      text-transparent bg-clip-text
      bg-[linear-gradient(90deg,#6b7280,#9ca3af,#4b5563,#d1d5db)]
      bg-[length:300%_100%] animate-gradient"
    >
      Desarrollador
    </span>

    <nav class="lg:hidden mt-10 sm:mt-12 flex flex-col gap-5 sm:gap-6">
      <a
        href={route("contact")}
        class="group text-xl sm:text-2xl font-semibold"
      >
        <span class="block h-[1px] w-12 mx-auto mb-3 bg-gray-400 group-hover:w-20 transition-all duration-300"></span>
        Contacto
      </a>

      <a
        href={route("blog")}
        class="group text-xl sm:text-2xl font-semibold"
      >
        <span class="block h-[1px] w-12 mx-auto mb-3 bg-gray-400 group-hover:w-20 transition-all duration-300"></span>
        Blog
      </a>
    </nav>
  </div>

  <div class="hidden lg:flex absolute right-[8%] flex-col gap-20 z-20">
    <a href={route("contact")} class="group relative">
      <div
        class="absolute top-1/2 left-[-180px] w-[160px] h-[1px]
        bg-gradient-to-l from-gray-600/100 to-transparent
        group-hover:w-[200px] transition-all duration-500"
      ></div>

      <span class="px-6 py-3 text-3xl transition-all duration-300 inline-block">
        Contacto
      </span>
    </a>

    <a href={route("blog")} class="group relative">
      <div
        class="absolute top-1/2 left-[-180px] w-[160px] h-[1px]
        bg-gradient-to-l from-gray-600/100 to-transparent
        group-hover:w-[200px] transition-all duration-500"
      ></div>

      <span class="px-6 py-3 text-3xl transition-all duration-300 inline-block">
        Blog
      </span>
    </a>
  </div>

</section>